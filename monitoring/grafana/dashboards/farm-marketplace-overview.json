{
  "dashboard": {
    "title": "🌾 Farm Marketplace — Overview",
    "uid": "farm-overview",
    "timezone": "browser",
    "refresh": "30s",
    "panels": [
      {
        "title": "Request Rate (req/s)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
        "targets": [
          {
            "expr": "sum(rate(http_server_requests_seconds_count{application=\"farm-marketplace\"}[5m]))",
            "legendFormat": "Total"
          },
          {
            "expr": "sum(rate(http_server_requests_seconds_count{application=\"farm-marketplace\",status=~\"5..\"}[5m]))",
            "legendFormat": "5xx Errors"
          }
        ]
      },
      {
        "title": "Response Time P95",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{application=\"farm-marketplace\"}[5m])) by (le))",
            "legendFormat": "P95"
          },
          {
            "expr": "histogram_quantile(0.50, sum(rate(http_server_requests_seconds_bucket{application=\"farm-marketplace\"}[5m])) by (le))",
            "legendFormat": "P50"
          }
        ]
      },
      {
        "title": "Orders Placed",
        "type": "stat",
        "gridPos": { "h": 4, "w": 4, "x": 0, "y": 8 },
        "targets": [
          {
            "expr": "increase(farm_orders_placed_total[24h])",
            "legendFormat": "24h"
          }
        ]
      },
      {
        "title": "Today's Revenue",
        "type": "stat",
        "gridPos": { "h": 4, "w": 4, "x": 4, "y": 8 },
        "targets": [
          {
            "expr": "farm_revenue_today / 100",
            "legendFormat": "USD"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "currencyUSD"
          }
        }
      },
      {
        "title": "Pending Orders",
        "type": "stat",
        "gridPos": { "h": 4, "w": 4, "x": 8, "y": 8 },
        "targets": [
          {
            "expr": "farm_orders_pending",
            "legendFormat": "Pending"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "steps": [
                { "color": "green", "value": 0 },
                { "color": "yellow", "value": 10 },
                { "color": "red", "value": 30 }
              ]
            }
          }
        }
      },
      {
        "title": "Active Products",
        "type": "stat",
        "gridPos": { "h": 4, "w": 4, "x": 12, "y": 8 },
        "targets": [
          {
            "expr": "farm_products_active"
          }
        ]
      },
      {
        "title": "Low Stock Products",
        "type": "stat",
        "gridPos": { "h": 4, "w": 4, "x": 16, "y": 8 },
        "targets": [
          {
            "expr": "farm_products_low_stock"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "steps": [
                { "color": "green", "value": 0 },
                { "color": "yellow", "value": 5 },
                { "color": "red", "value": 15 }
              ]
            }
          }
        }
      },
      {
        "title": "Active Users",
        "type": "stat",
        "gridPos": { "h": 4, "w": 4, "x": 20, "y": 8 },
        "targets": [
          {
            "expr": "farm_users_active"
          }
        ]
      },
      {
        "title": "JVM Heap Usage",
        "type": "gauge",
        "gridPos": { "h": 6, "w": 6, "x": 0, "y": 12 },
        "targets": [
          {
            "expr": "jvm_memory_used_bytes{area=\"heap\"} / jvm_memory_max_bytes{area=\"heap\"}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "max": 1,
            "thresholds": {
              "steps": [
                { "color": "green", "value": 0 },
                { "color": "yellow", "value": 0.7 },
                { "color": "red", "value": 0.85 }
              ]
            }
          }
        }
      },
      {
        "title": "Service Method Duration",
        "type": "timeseries",
        "gridPos": { "h": 6, "w": 18, "x": 6, "y": 12 },
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum(rate(farm_service_duration_seconds_bucket{outcome=\"SUCCESS\"}[5m])) by (le, class, method))",
            "legendFormat": "{{class}}.{{method}}"
          }
        ]
      },
      {
        "title": "Payment Success vs Failure",
        "type": "piechart",
        "gridPos": { "h": 6, "w": 6, "x": 0, "y": 18 },
        "targets": [
          {
            "expr": "increase(farm_payments_processed_total[24h])",
            "legendFormat": "Success"
          },
          {
            "expr": "increase(farm_payments_failed_total[24h])",
            "legendFormat": "Failed"
          }
        ]
      },
      {
        "title": "Order Value Distribution",
        "type": "histogram",
        "gridPos": { "h": 6, "w": 18, "x": 6, "y": 18 },
        "targets": [
          {
            "expr": "farm_order_value_usd_bucket",
            "legendFormat": "{{le}}"
          }
        ]
      }
    ]
  }
}